---
import Layout from '../layouts/Layout.astro'; // Adjust path if needed
---

<Layout>
  <div class="w-full border-b border-[#111111]/20 py-3 px-8 flex justify-between items-center font-mono text-[10px] sm:text-xs uppercase tracking-widest text-[#111111]/60">
    <span>System: Online</span>
    <div class="flex gap-6 sm:gap-12 animate-pulse">
      <span>$IBIT: +1.2%</span>
      <span class="hidden sm:inline">Guitar: C-Major Pentatonic</span>
      <span>Son: Day 142</span>
      <span class="hidden md:inline">Chess: 1450 ELO</span>
    </div>
  </div>

  <div class="max-w-5xl mx-auto px-8 md:px-16 pt-24 pb-32">
    
    <header class="mb-32">
      <h1 class="text-5xl sm:text-7xl md:text-8xl font-serif font-bold text-[#111111] leading-[1.05] tracking-tight">
        Seek Wisdom,<br/>Not Information.
      </h1>
    </header>

    <div class="flex flex-col gap-0 border-t border-[#111111]/20">
      
      <a href="/lab" class="group flex flex-col md:flex-row md:items-baseline justify-between py-12 border-b border-[#111111]/20 hover:bg-[#111111]/5 transition-colors cursor-crosshair">
        <div class="flex items-baseline gap-6 md:gap-12">
          <span class="font-serif text-2xl text-[#111111]/40 group-hover:text-[#111111] transition-colors">I.</span>
          <h2 class="font-serif text-4xl sm:text-5xl font-bold group-hover:italic transition-all">The Lab</h2>
        </div>
        <p class="font-mono text-xs tracking-widest uppercase mt-4 md:mt-0 text-[#111111]/60 group-hover:text-[#111111] transition-colors">Intelligence & Artificial Systems</p>
      </a>

      <a href="/ledger" class="group flex flex-col md:flex-row md:items-baseline justify-between py-12 border-b border-[#111111]/20 hover:bg-[#111111]/5 transition-colors">
        <div class="flex items-baseline gap-6 md:gap-12">
          <span class="font-serif text-2xl text-[#111111]/40 group-hover:text-[#111111] transition-colors">II.</span>
          <h2 class="font-serif text-4xl sm:text-5xl font-bold group-hover:italic transition-all">The Ledger</h2>
        </div>
        <p class="font-mono text-xs tracking-widest uppercase mt-4 md:mt-0 text-[#111111]/60 group-hover:text-[#111111] transition-colors">Capital & Mental Models</p>
      </a>

      <a href="/library" class="group flex flex-col md:flex-row md:items-baseline justify-between py-12 border-b border-[#111111]/20 hover:bg-[#111111]/5 transition-colors">
        <div class="flex items-baseline gap-6 md:gap-12">
          <span class="font-serif text-2xl text-[#111111]/40 group-hover:text-[#111111] transition-colors">III.</span>
          <h2 class="font-serif text-4xl sm:text-5xl font-bold group-hover:italic transition-all">The Library</h2>
        </div>
        <p class="font-mono text-xs tracking-widest uppercase mt-4 md:mt-0 text-[#111111]/60 group-hover:text-[#111111] transition-colors">Wisdom & Systematic Curiosity</p>
      </a>

      <a href="/lattice" class="group flex flex-col md:flex-row md:items-baseline justify-between py-12 border-b border-[#111111]/20 hover:bg-[#111111]/5 transition-colors">
        <div class="flex items-baseline gap-6 md:gap-12">
          <span class="font-serif text-2xl text-[#111111]/40 group-hover:text-[#111111] transition-colors">IV.</span>
          <h2 class="font-serif text-4xl sm:text-5xl font-bold group-hover:italic transition-all">The Lattice</h2>
        </div>
        <p class="font-mono text-xs tracking-widest uppercase mt-4 md:mt-0 text-[#111111]/60 group-hover:text-[#111111] transition-colors">Practice & Multidisciplinary Mastery</p>
      </a>

      <a href="/legacy" class="group flex flex-col md:flex-row md:items-baseline justify-between py-12 border-b border-[#111111]/20 hover:bg-[#F2EFE9] transition-colors">
        <div class="flex items-baseline gap-6 md:gap-12">
          <span class="font-serif text-2xl text-[#111111]/40 group-hover:text-[#111111] transition-colors">V.</span>
          <h2 class="font-serif text-4xl sm:text-5xl font-bold group-hover:italic transition-all">The Legacy</h2>
        </div>
        <p class="font-mono text-xs tracking-widest uppercase mt-4 md:mt-0 text-[#111111]/60 group-hover:text-[#111111] transition-colors">Genesis & The Alchemist's Journal</p>
      </a>

    </div>
  </div>
</Layout>
