---
import '../styles/global.css'; // Ensure this points to your CSS file
---

<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width" />
    <title>Abhiket | The Analytical Sanctuary</title>
  </head>
  <body class="bg-[#FAF9F6] text-[#111111] min-h-screen flex">
    
    <aside class="fixed top-0 left-0 h-screen w-16 md:w-24 border-r border-[#111111]/20 flex flex-col items-center justify-between py-12 z-50 bg-[#FAF9F6]">
      
      <a href="/" class="font-serif font-bold text-xl hover:opacity-50 transition-opacity">AG</a>

      <nav class="flex flex-col gap-12 text-center">
        <a href="/lab" class="font-serif text-sm font-bold hover:italic relative group" title="Intelligence">I<span class="absolute left-10 opacity-0 group-hover:opacity-100 font-sans text-xs tracking-widest uppercase transition-opacity whitespace-nowrap">Lab</span></a>
        
        <a href="/ledger" class="font-serif text-sm font-bold hover:italic relative group" title="Capital">II<span class="absolute left-10 opacity-0 group-hover:opacity-100 font-sans text-xs tracking-widest uppercase transition-opacity whitespace-nowrap">Ledger</span></a>
        
        <a href="/library" class="font-serif text-sm font-bold hover:italic relative group" title="Wisdom">III<span class="absolute left-10 opacity-0 group-hover:opacity-100 font-sans text-xs tracking-widest uppercase transition-opacity whitespace-nowrap">Library</span></a>
        
        <a href="/lattice" class="font-serif text-sm font-bold hover:italic relative group" title="Practice">IV<span class="absolute left-10 opacity-0 group-hover:opacity-100 font-sans text-xs tracking-widest uppercase transition-opacity whitespace-nowrap">Lattice</span></a>
        
        <a href="/legacy" class="font-serif text-sm font-bold hover:italic relative group" title="Genesis">V<span class="absolute left-10 opacity-0 group-hover:opacity-100 font-sans text-xs tracking-widest uppercase transition-opacity whitespace-nowrap">Legacy</span></a>
      </nav>

      <div class="h-6 w-px bg-[#111111]/20"></div>
    </aside>

    <main class="ml-16 md:ml-24 flex-1 min-h-screen w-full relative overflow-x-hidden">
      <slot />
    </main>

  </body>
</html>
