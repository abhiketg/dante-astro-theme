---
import siteConfig from '../data/site-config';
---

<header class="w-full py-8 flex items-center justify-end relative z-50">
  
  <nav class="ml-auto flex items-center gap-6 sm:gap-8">
    <ul class="flex items-center gap-6 sm:gap-8 m-0 p-0 list-none">
      {
        siteConfig.headerNavLinks.map((link) => (
          <li>
            <a
              href={link.href}
              class="font-sans text-xs sm:text-sm font-bold tracking-[0.15em] uppercase text-gray-500 hover:text-gray-900 dark:text-gray-400 dark:hover:text-white transition-colors"
            >
              {link.text}
            </a>
          </li>
        ))
      }
    </ul>
  </nav>
  
</header>
