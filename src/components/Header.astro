---
import siteConfig from '../data/site-config';

// Note: If your theme has a dark/light mode toggle, keep its import here. 
// For Dante, it usually looks like: import ThemeToggle from './ThemeToggle.astro';
---

<header class="w-full py-8 px-6 md:px-12 lg:px-16 max-w-7xl mx-auto flex items-center justify-end z-50 relative">
  <nav class="flex items-center gap-6 sm:gap-8">
    <ul class="flex items-center gap-6 sm:gap-8 m-0 p-0 list-none">
      {
        siteConfig.headerNavLinks.map((link) => (
          <li>
            <a
              href={link.href}
              class="font-sans text-xs sm:text-sm font-bold tracking-[0.15em] uppercase text-gray-500 hover:text-gray-900 dark:text-gray-400 dark:hover:text-white transition-colors"
            >
              {link.text}
            </a>
          </li>
        ))
      }
    </ul>
    
    </nav>
</header>
