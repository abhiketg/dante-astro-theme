---
import { Image } from 'astro:assets';
const { title, subtitle, text, image, actions } = Astro.props;
---

<section class="w-full max-w-7xl mx-auto px-6 lg:px-8 pt-8 pb-16 md:pt-12 md:pb-24">
  <div class="grid grid-cols-1 lg:grid-cols-[minmax(300px,450px)_1fr] gap-10 lg:gap-16 items-center">
    
    <div class="relative w-full aspect-[4/5] rounded-2xl overflow-hidden shadow-2xl bg-neutral-900">
      <Image 
        src={image.src} 
        alt={image.alt} 
        class="absolute inset-0 w-full h-full object-cover grayscale transition-all duration-700 hover:grayscale-0"
        style="mask-image: linear-gradient(to bottom, black 70%, transparent 100%); -webkit-mask-image: linear-gradient(to bottom, black 70%, transparent 100%);"
      />
    </div>

    <div class="flex flex-col items-start text-left">
      <h1 class="font-sans text-5xl sm:text-6xl lg:text-7xl font-extrabold tracking-tight text-gray-900 dark:text-white leading-[1.1] mb-4">
        Hi there! I'm {title}.
      </h1>
      
      <p class="font-sans text-[11px] sm:text-xs font-bold uppercase tracking-[0.2em] text-blue-600 dark:text-blue-400 mb-8">
        {subtitle}
      </p>

      <div class="prose prose-lg max-w-2xl font-serif text-gray-700 dark:text-gray-300 leading-relaxed">
        {text.split('\n\n').map((paragraph) => (
          <p class="mb-5 last:mb-0">{paragraph}</p>
        ))}
      </div>

      {actions && actions.length > 0 && (
        <div class="mt-8">
          {actions.map((action) => (
            <a href={action.href} class="inline-flex rounded-full border border-gray-900 dark:border-white/20 bg-transparent dark:bg-white/5 px-8 py-3 text-sm font-bold tracking-wide text-gray-900 dark:text-white transition-all hover:bg-gray-900 hover:text-white dark:hover:bg-white dark:hover:text-black">
              {action.text}
            </a>
          ))}
        </div>
      )}
    </div>
    
  </div>
</section>
