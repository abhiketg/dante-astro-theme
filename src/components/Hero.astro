---
import { Image } from 'astro:assets';
interface Props {
  title: string;
  subtitle?: string;
  text: string;
  image?: {
    src: any;
    alt: string;
  };
  actions?: {
    text: string;
    href: string;
  }[];
}

const { title, subtitle, text, image, actions } = Astro.props;
---

<section class="min-h-screen flex items-center justify-center bg-black text-white p-6 md:p-12">
  <div class="grid md:grid-cols-2 gap-12 items-center max-w-7xl mx-auto w-full">
    
    {image && (
      <div class="flex justify-center md:justify-end">
        <Image 
          src={image.src} 
          alt={image.alt} 
          class="rounded-lg shadow-2xl object-cover w-full h-auto max-w-sm md:max-w-md aspect-[3/4]"
        />
      </div>
    )}

    <div class="flex flex-col space-y-6 text-center md:text-left">
      <h1 class="text-5xl md:text-7xl font-serif leading-tight">
        {title}
      </h1>
      
      {subtitle && (
        <p class="text-xl md:text-2xl font-light text-gray-300">
          {subtitle}
        </p>
      )}
      
      <p class="text-lg md:text-xl text-gray-400 max-w-lg mx-auto md:mx-0 whitespace-pre-line">
        {text}
      </p>
      
      {actions && actions.length > 0 && (
        <div class="flex flex-col sm:flex-row gap-4 pt-6 justify-center md:justify-start">
          {actions.map((action) => (
            <a 
              href={action.href} 
              class="inline-block px-8 py-3 border-2 border-white rounded-full text-white hover:bg-white hover:text-black transition duration-300"
            >
              {action.text}
            </a>
          ))}
        </div>
      )}
    </div>
  </div>
</section>
