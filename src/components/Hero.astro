---
import { Image } from 'astro:assets';
const { title, subtitle, text, image, actions } = Astro.props;
---

<section class="relative mx-auto max-w-none px-0 -mt-10 mb-20">
  <div class="flex flex-col md:flex-row items-center justify-between gap-10 lg:gap-16">
    
    <div class="w-full md:w-3/5 lg:w-2/3 flex flex-col items-start">
      <h1 class="mb-4 font-sans font-extrabold tracking-tight text-white leading-none whitespace-nowrap" style="font-size: clamp(2rem, 8vw, 4.5rem);">
        Hi there! I'm {title}.
      </h1>
      
      <p class="mb-8 font-sans text-[10px] font-bold uppercase tracking-[0.2em] text-blue-400 sm:text-xs whitespace-nowrap overflow-visible">
        {subtitle}
      </p>

      <div class="max-w-xl font-sans text-base leading-relaxed text-gray-400 antialiased sm:text-lg">
        {text.split('\n\n').map((paragraph) => (
          <p class="mb-4 last:mb-0">{paragraph}</p>
        ))}
      </div>

      {actions && actions.length > 0 && (
        <div class="mt-8">
          {actions.map((action) => (
            <a href={action.href} class="inline-block rounded-full border border-white/20 bg-white/5 px-8 py-3 text-sm font-semibold text-white transition-all hover:bg-white hover:text-black">
              {action.text}
            </a>
          ))}
        </div>
      )}
    </div>

    <div class="hidden md:block w-full md:w-2/5 lg:w-1/3 shrink-0">
      <div class="relative overflow-hidden rounded-2xl shadow-2xl">
        <Image 
          src={image.src} 
          alt={image.alt} 
          class="h-auto w-full object-cover grayscale transition-all duration-700 hover:grayscale-0"
          style="mask-image: linear-gradient(to bottom, black 80%, transparent 100%); -webkit-mask-image: linear-gradient(to bottom, black 80%, transparent 100%);"
        />
      </div>
    </div>
  </div>
</section>
