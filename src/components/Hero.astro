---
import { Image } from 'astro:assets';
const { title, subtitle, text, image, actions } = Astro.props;
---

<section class="relative mb-12 pt-4 sm:mb-20 sm:pt-8">
  <div class="grid grid-cols-1 items-center gap-10 md:grid-cols-[1fr_1.8fr] lg:gap-16">
    <div class="relative order-1 max-w-[320px] md:max-w-none justify-self-center md:justify-self-start">
      <div class="relative overflow-hidden rounded-xl shadow-xl transition-all duration-500 hover:shadow-2xl">
        <Image 
          src={image.src} 
          alt={image.alt} 
          class="h-auto w-full object-cover grayscale transition-all duration-700 hover:grayscale-0"
          style="mask-image: linear-gradient(to bottom, rgba(0,0,0,1) 85%, rgba(0,0,0,0) 100%); -webkit-mask-image: linear-gradient(to bottom, rgba(0,0,0,1) 85%, rgba(0,0,0,0) 100%);"
        />
      </div>
    </div>

    <div class="flex flex-col order-2">
      <h1 class="mb-1 font-serif text-4xl font-bold tracking-tight text-primary sm:text-5xl lg:text-7xl xl:whitespace-nowrap">
        {title}
      </h1>
      
      <p class="mb-8 font-sans text-xs font-bold uppercase tracking-[0.2em] text-muted-foreground sm:text-sm lg:whitespace-nowrap">
        {subtitle}
      </p>

      <div class="prose prose-neutral dark:prose-invert max-w-none font-serif text-lg leading-relaxed text-secondary-foreground/90">
        {text.split('\n\n').map((paragraph) => (
          <p class="mb-4 last:mb-0">{paragraph}</p>
        ))}
      </div>

      {actions && actions.length > 0 && (
        <div class="mt-8 flex flex-wrap gap-4">
          {actions.map((action) => (
            <a href={action.href} class="rounded-full bg-primary px-6 py-2.5 text-sm font-medium text-primary-foreground transition-all hover:opacity-90">
              {action.text}
            </a>
          ))}
        </div>
      )}
    </div>
  </div>
</section>
