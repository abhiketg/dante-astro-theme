---
import { Image } from 'astro:assets';
interface Props {
  title: string;
  subtitle?: string;
  text: string;
  image?: {
    src: any;
    alt: string;
  };
  actions?: {
    text: string;
    href: string;
  }[];
}

const { title, subtitle, text, image, actions } = Astro.props;
---

<section class="py-16 sm:py-24 md:py-32">
  <div class="grid md:grid-cols-2 gap-12 items-center max-w-6xl mx-auto px-6">
    
    {image && (
      <div class="flex justify-center md:justify-end order-1">
        <Image 
          src={image.src} 
          alt={image.alt} 
          class="rounded-xl shadow-xl object-cover w-full max-w-sm aspect-[4/5]"
          loading="eager"
        />
      </div>
    )}

    <div class="flex flex-col space-y-6 text-left order-2">
      <h1 class="text-4xl md:text-6xl font-serif leading-tight text-gray-900 dark:text-white">
        {title}
      </h1>
      
      {subtitle && (
        <p class="text-lg md:text-xl font-medium text-gray-600 dark:text-gray-400">
          {subtitle}
        </p>
      )}
      
      <div class="text-lg text-gray-700 dark:text-gray-300 whitespace-pre-line leading-relaxed">
        {text}
      </div>
      
      {actions && actions.length > 0 && (
        <div class="flex flex-wrap gap-4 pt-4">
          {actions.map((action) => (
            <a 
              href={action.href} 
              class="inline-block px-6 py-2 border-2 border-black dark:border-white rounded-md hover:bg-black hover:text-white dark:hover:bg-white dark:hover:text-black transition-all"
            >
              {action.text}
            </a>
          ))}
        </div>
      )}
    </div>
  </div>
</section>
