---
import { Image } from 'astro:assets';
const { title, subtitle, text, image } = Astro.props;
---

<section class="relative mx-auto max-w-6xl px-4 pt-0 sm:pt-4 mb-12">
  <div class="flex flex-col md:flex-row items-start gap-12 lg:gap-20">
    
    <div class="w-full md:w-5/12 shrink-0">
      <div class="relative overflow-hidden rounded-lg shadow-2xl bg-neutral-900">
        <Image 
          src={image.src} 
          alt={image.alt} 
          class="h-auto w-full object-cover grayscale hover:grayscale-0 transition-all duration-700"
          style="mask-image: linear-gradient(to bottom, black 80%, transparent 100%); -webkit-mask-image: linear-gradient(to bottom, black 80%, transparent 100%);"
        />
      </div>
    </div>

    <div class="w-full md:w-7/12 pt-4">
      <h1 class="mb-2 font-serif text-5xl font-bold tracking-tight text-white lg:text-7xl leading-none">
        {title}
      </h1>
      
      <p class="mb-8 font-sans text-xs font-bold uppercase tracking-[0.3em] text-neutral-400">
        {subtitle}
      </p>

      <div class="prose prose-invert max-w-none font-serif text-lg leading-relaxed text-neutral-300">
        {text.split('\n\n').map((paragraph) => (
          <p class="mb-6 last:mb-0">{paragraph}</p>
        ))}
      </div>
    </div>
  </div>
</section>
