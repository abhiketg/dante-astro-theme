---
import { Image } from 'astro:assets';
const { title, subtitle, text, image, actions } = Astro.props;
---

<section class="relative mx-auto max-w-7xl px-4 -mt-8 mb-16">
  <div class="flex flex-col md:flex-row items-start justify-between gap-12">
    
    <div class="w-full md:w-2/3 lg:w-3/4">
      <h1 class="mb-4 font-sans text-4xl font-extrabold tracking-tight text-white sm:text-5xl lg:text-6xl whitespace-nowrap">
        Hi there! I'm {title}.
      </h1>
      
      <p class="mb-8 font-sans text-[10px] font-bold uppercase tracking-[0.15em] text-blue-400 sm:text-xs whitespace-nowrap">
        {subtitle}
      </p>

      <div class="max-w-2xl font-sans text-base leading-relaxed text-gray-400 antialiased sm:text-lg">
        {text.split('\n\n').map((paragraph) => (
          <p class="mb-4 last:mb-0">{paragraph}</p>
        ))}
      </div>

      {actions && actions.length > 0 && (
        <div class="mt-8">
          {actions.map((action) => (
            <a href={action.href} class="inline-block rounded-full border border-white/20 bg-white/5 px-6 py-2 text-sm font-medium text-white transition-all hover:bg-white hover:text-black">
              {action.text}
            </a>
          ))}
        </div>
      )}
    </div>

    <div class="hidden md:block w-full md:w-1/3 lg:w-1/4">
      <div class="relative overflow-hidden rounded-2xl shadow-2xl shadow-blue-500/10">
        <Image 
          src={image.src} 
          alt={image.alt} 
          class="h-auto w-full object-cover grayscale transition-all duration-700 hover:grayscale-0"
          style="mask-image: linear-gradient(to bottom, black 85%, transparent 100%); -webkit-mask-image: linear-gradient(to bottom, black 85% , transparent 100%);"
        />
      </div>
    </div>
  </div>
</section>
