---
import { Image } from 'astro:assets';
const { title, subtitle, text, image } = Astro.props;
---

<section class="relative mx-auto max-w-7xl px-4 -mt-10 sm:-mt-16 mb-12">
  <div class="flex flex-col-reverse md:flex-row items-center justify-between gap-8 lg:gap-12">
    
    <div class="w-full md:w-3/5 lg:w-2/3">
      <h1 class="mb-4 font-sans text-5xl font-extrabold tracking-tight text-white sm:text-6xl lg:text-8xl leading-[1.1]">
        Hi there! I'm {title.split(' ')[0]}.
      </h1>
      
      <p class="mb-10 font-sans text-sm font-bold uppercase tracking-[0.2em] text-blue-400 opacity-90">
        {subtitle}
      </p>

      <div class="max-w-2xl font-sans text-lg md:text-xl leading-relaxed text-gray-300 antialiased">
        {text.split('\n\n').map((paragraph) => (
          <p class="mb-6 last:mb-0">{paragraph}</p>
        ))}
      </div>
    </div>

    <div class="w-full md:w-2/5 lg:w-1/3 flex justify-center md:justify-end">
      <div class="relative w-full max-w-[400px]">
        <Image 
          src={image.src} 
          alt={image.alt} 
          class="h-auto w-full object-cover grayscale hover:grayscale-0 transition-all duration-700 rounded-2xl shadow-2xl"
          style="mask-image: linear-gradient(to bottom, black 80%, transparent 100%); -webkit-mask-image: linear-gradient(to bottom, black 80%, transparent 100%);"
        />
      </div>
    </div>
  </div>
</section>
