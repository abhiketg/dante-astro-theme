---
import { Image } from 'astro:assets';
const { title, subtitle, text, image, actions } = Astro.props;
---

<section class="relative w-[100vw] left-[50%] right-[50%] -ml-[50vw] -mr-[50vw] -mt-16 sm:-mt-24 pt-16 sm:pt-24 mb-16 overflow-hidden">
  <div class="mx-auto max-w-7xl px-6 md:px-12 lg:px-16">
    <div class="flex flex-col md:flex-row items-center justify-between gap-12 lg:gap-24">
      
      <div class="w-full md:w-[380px] lg:w-[460px] shrink-0 flex justify-center md:justify-start">
        <div class="relative w-full h-[450px] sm:h-[500px] lg:h-[600px] overflow-hidden group">
          <Image 
            src={image.src} 
            alt={image.alt} 
            class="absolute inset-0 w-full h-full object-cover grayscale transition-all duration-1000 group-hover:grayscale-0 rounded-xl"
            style="mask-image: linear-gradient(to bottom, rgba(0,0,0,1) 65%, rgba(0,0,0,0) 100%); -webkit-mask-image: linear-gradient(to bottom, rgba(0,0,0,1) 65%, rgba(0,0,0,0) 100%);"
          />
        </div>
      </div>

      <div class="flex-1 w-full flex flex-col justify-center items-start pt-4">
        
        <h1 
          class="font-sans font-extrabold tracking-tighter text-gray-900 dark:text-white whitespace-nowrap mb-2 transition-colors"
          style="font-size: clamp(2.5rem, 6vw, 5.5rem); line-height: 1.1;"
        >
          Hi there! I'm {title}.
        </h1>
        
        <p class="font-sans text-[0.65rem] sm:text-[11px] font-black uppercase tracking-[0.25em] text-blue-600 dark:text-blue-400 whitespace-nowrap mb-8 overflow-visible transition-colors">
          {subtitle}
        </p>

        <div class="max-w-xl font-serif text-base sm:text-lg leading-relaxed text-gray-700 dark:text-gray-300 transition-colors">
          {text.split('\n\n').map((paragraph) => (
            <p class="mb-5 last:mb-0">{paragraph}</p>
          ))}
        </div>

        {actions && actions.length > 0 && (
          <div class="mt-8">
            {actions.map((action) => (
              <a href={action.href} class="inline-flex items-center justify-center rounded-full border border-gray-900 dark:border-white/20 bg-transparent dark:bg-white/5 px-8 py-3.5 text-sm font-bold tracking-wide text-gray-900 dark:text-white transition-all duration-300 hover:bg-gray-900 hover:text-white dark:hover:bg-white dark:hover:text-black hover:scale-105 active:scale-95">
                {action.text}
              </a>
            ))}
          </div>
        )}
      </div>

    </div>
  </div>
</section>
